[user]
	name = Vadim Caen
	email = caen@google.com
[color]
	ui = auto
[alias]
	st = status
	a = add -A
	ai = add -i
	ap = add -p
	ci = commit
	cf = commit --fixup
	cia = commit -a
	ciamn = commit -a --amend --no-edit
	ciam = commit -a --amend
	cm = commit --amend
	cmn = commit --amend --no-edit
	co = checkout
	b = branch --sort=-committerdate -v
	d = difftool --dir-diff
	rc = rebase --continue
	ri = rebase -i
	ria = rebase -i --autosquash
	ll = log --pretty=format:\"%Cgreen%h %>(10,trunc)%C(cyan)%aN %Creset%s\" -n 10
	dsh = diff --stat HEAD~1
	ds = diff --stat
	dh =  diff HEAD~1
	reball = ! gitrebase
	con = ! gitbranchnum
	dn = "!sh -c 'if [ $# -eq 0 ] ; then git d HEAD~1 HEAD ; else git d HEAD~`expr $1 + 1` HEAD~$1 ; fi' -"
	reskeep = "!git reset HEAD~1 && git commit --allow-empty -C HEAD@{1} "

[diff]
    tool = kitty
    guitool = kitty.gui

[difftool]
    prompt = false
    trustExitCode = true

[difftool "kitty"]
    cmd = kitty +kitten diff $LOCAL $REMOTE

[difftool "kitty.gui"]
    cmd = kitty kitty +kitten diff $LOCAL $REMOTE

[http]
	cookiefile = ~/.gitcookies
[log]
	date = iso
[core]
	pager = less -FRX
	excludesfile = ~/.personal_gitignore
[pager]
	log = true
